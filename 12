class CoupleOrderLine(BaseModel):
    name: str
    qty: int = Field(default=1, ge=1)


class CoupleOrderCreateRequest(BaseModel):
    room_id: str = Field(min_length=1, max_length=64)
    sender: Optional[str] = Field(default="点单端")
    total_qty: int = Field(ge=1)
    lines: List[CoupleOrderLine]


class CoupleOrderAckRequest(BaseModel):
    room_id: str = Field(min_length=1, max_length=64)
    receiver: Optional[str] = Field(default="接单端")


