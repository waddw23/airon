services:
  - type: web
    name: airon-omnicore-api
    runtime: python
    plan: free
    autoDeploy: true
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn omnicore_api:app --host 0.0.0.0 --port $PORT
    envVars:
      - key: COZE_API_KEY
        sync: false
      - key: COZE_BOT_ID
        value: 7619599264641089582
      - key: COZE_USER_ID
        value: user9093316760
      - key: COZE_API_BASE
        value: https://api.coze.cn
